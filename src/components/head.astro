<script is:inline>
  const FILE_PATH_PATTERN =
    /^(?:\.{1,2}[\\/]|[A-Za-z]:[\\/]|\/)?(?:[^\\/\s]+[\\/])+[^\\/\s]+$/;

  function isProbablyFilePath(value) {
    if (!value) return false;
    if (value.length < 3 || value.length > 180) return false;
    if (!FILE_PATH_PATTERN.test(value)) return false;
    return /[\\/]/.test(value);
  }

  function legacyCopyToClipboard(text) {
    const textarea = document.createElement("textarea");
    textarea.value = text;
    textarea.setAttribute("readonly", "");
    textarea.style.position = "fixed";
    textarea.style.top = "-1000px";
    textarea.style.left = "-1000px";
    document.body.appendChild(textarea);
    textarea.focus();
    textarea.select();

    let ok = false;
    try {
      ok = document.execCommand("copy");
    } catch {
      ok = false;
    }

    document.body.removeChild(textarea);
    return ok;
  }

  async function copyToClipboard(text, trigger) {
    try {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(text);
      } else {
        const copied = legacyCopyToClipboard(text);
        if (!copied) throw new Error("Clipboard unavailable");
      }

      const previous = trigger.textContent;
      trigger.textContent = "Copiado";
      trigger.classList.add("is-copied");
      window.setTimeout(() => {
        trigger.textContent = previous;
        trigger.classList.remove("is-copied");
      }, 1400);
    } catch {
      const copied = legacyCopyToClipboard(text);
      if (copied) {
        const previous = trigger.textContent;
        trigger.textContent = "Copiado";
        trigger.classList.add("is-copied");
        window.setTimeout(() => {
          trigger.textContent = previous;
          trigger.classList.remove("is-copied");
        }, 1400);
      } else {
        trigger.textContent = "Error";
        window.setTimeout(() => {
          trigger.textContent = "Copiar";
        }, 1400);
      }
    }
  }

  function createCopyButton(text) {
    const button = document.createElement("button");
    button.type = "button";
    button.className = "path-copy__button";
    button.textContent = "Copiar";
    button.setAttribute("aria-label", `Copiar ruta ${text}`);
    button.addEventListener("click", () => copyToClipboard(text, button));
    return button;
  }

  function decoratePathCode(codeEl) {
    if (codeEl.dataset.pathCopyReady === "true") return;
    const rawText = codeEl.textContent?.trim() ?? "";
    if (!isProbablyFilePath(rawText)) return;

    const wrapper = document.createElement("span");
    wrapper.className = "path-copy";

    const button = createCopyButton(rawText);

    codeEl.dataset.pathCopyReady = "true";
    const parent = codeEl.parentNode;
    if (!parent) return;

    parent.insertBefore(wrapper, codeEl);
    wrapper.appendChild(codeEl);
    wrapper.appendChild(button);
  }

  function decoratePathParagraph(paragraphEl) {
    if (paragraphEl.dataset.pathCopyReady === "true") return;
    if (paragraphEl.querySelector("code, a, button")) return;
    const rawText = paragraphEl.textContent?.trim() ?? "";
    if (!isProbablyFilePath(rawText)) return;

    paragraphEl.dataset.pathCopyReady = "true";
    paragraphEl.classList.add("path-copy-paragraph");
    paragraphEl.appendChild(document.createTextNode(" "));
    paragraphEl.appendChild(createCopyButton(rawText));
  }

  function scanAndDecorate(root = document) {
    const inlineCodeCandidates = root.querySelectorAll(
      ".sl-markdown-content p > code, .sl-markdown-content li > code, .sl-markdown-content td > code"
    );
    inlineCodeCandidates.forEach((node) => decoratePathCode(node));

    const blockquotePathCandidates = root.querySelectorAll(
      ".sl-markdown-content blockquote p"
    );
    blockquotePathCandidates.forEach((node) => decoratePathParagraph(node));
  }

  const observer = new MutationObserver((mutations) => {
    for (const mutation of mutations) {
      mutation.addedNodes.forEach((node) => {
        if (node instanceof HTMLElement) {
          scanAndDecorate(node);
        }
      });
    }
  });

  let observerStarted = false;
  function initPathCopy() {
    scanAndDecorate();
    if (!observerStarted) {
      observer.observe(document.body, { childList: true, subtree: true });
      observerStarted = true;
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initPathCopy, { once: true });
  } else {
    initPathCopy();
  }

  // Astro/Starlight client-side navigation events.
  document.addEventListener("astro:page-load", initPathCopy);
  document.addEventListener("astro:after-swap", initPathCopy);
</script>
